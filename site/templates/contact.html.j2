{% extends "base.html.j2" %}

{% block title %}Contact — Meridian Advisory{% endblock %}

{% block content %}
<section class="hero">
    <div class="marg">
        <aside class="marg-aside hero-aside">
            <p class="section-num">01 / Contact</p>
            <p class="label" style="margin-top: var(--md-px-4);">Perth WA<br>Mon–Fri<br>09:00–18:00 AWST</p>
        </aside>
        <div>
            <p class="eyebrow">Get in touch</p>
            <h1 class="display">Start a <span class="accent-rule">conversation.</span></h1>
            <p class="hero-tagline">Meridian accepts new clients on the strength of the question, not the size of the budget. The fastest route to a conversation is a short note about what you are trying to figure out.</p>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="marg">
        <aside class="marg-aside">
            <p class="section-num">02 / Channels</p>
        </aside>
        <div>
            <p class="exhibit-label">Exhibit&nbsp;01<span class="exhibit-label-title">&nbsp;Ways to reach the firm</span></p>

            <div class="practices">
                <div class="practice-row">
                    <div class="practice-num">01</div>
                    <div>
                        <div class="practice-title">New client enquiries</div>
                        <p class="practice-desc">Send a short note about the question you are trying to answer. A partner will respond personally within two business days.</p>
                    </div>
                    <div class="practice-meta">
                        <strong>enquiries@meridianadvisory.com.au</strong><br>
                        2 business days
                    </div>
                </div>
                <div class="practice-row">
                    <div class="practice-num">02</div>
                    <div>
                        <div class="practice-title">Existing clients</div>
                        <p class="practice-desc">Please contact your engagement partner directly. For urgent matters outside their availability, our reception team will route to the appropriate partner.</p>
                    </div>
                    <div class="practice-meta">
                        <strong>+61 8 6000 0000</strong><br>
                        09:00–18:00 AWST
                    </div>
                </div>
                <div class="practice-row">
                    <div class="practice-num">03</div>
                    <div>
                        <div class="practice-title">Careers and recruitment</div>
                        <p class="practice-desc">All open positions are listed on the careers page. For general enquiries about working at Meridian, write to our talent team.</p>
                    </div>
                    <div class="practice-meta">
                        <strong>careers@meridianadvisory.com.au</strong><br>
                        5 business days
                    </div>
                </div>
                <div class="practice-row">
                    <div class="practice-num">04</div>
                    <div>
                        <div class="practice-title">Office</div>
                        <p class="practice-desc">By appointment. Most initial conversations begin by phone or video — we hold in-person meetings at the client's office or at our Perth office.</p>
                    </div>
                    <div class="practice-meta">
                        <strong>Level 18, 240 St Georges Tce</strong><br>
                        Perth WA 6000
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-pad" style="background: var(--md-bg-2); border-top: 1px solid var(--md-line); border-bottom: 1px solid var(--md-line);">
    <div class="marg">
        <aside class="marg-aside">
            <p class="section-num">03 / Probity</p>
        </aside>
        <div>
            <p class="eyebrow">A note on independence</p>
            <h2 style="margin-bottom: var(--md-px-4); max-width: 22ch;">Meridian operates under strict probity and independence standards.</h2>
            <p style="color: var(--md-text-muted); font-size: 1.05rem; line-height: 1.75; max-width: 60ch;">
                Engagements are subject to conflict-of-interest checks, declared at proposal stage. Our independence policy and probity protocols are available on request, and all government engagements are conducted under the relevant probity frameworks.
            </p>
        </div>
    </div>
</section>

{% endblock %}
