<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Meridian Advisory — Clarity in Complexity{% endblock %}</title>
    <meta name="description" content="{% block description %}Meridian is a boutique Western Australian management consulting firm. Strategy, operations, digital transformation, and government policy advisory — partner-led on every engagement.{% endblock %}">
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="stylesheet" href="/styles/main.css">
    {% block head_extra %}{% endblock %}
</head>
<body>
    <header class="header">
        <div class="header-inner">
            <a href="/" class="brand">
                <div class="brand-mark">M</div>
                <div class="brand-name">
                    <strong>Meridian Advisory</strong>
                    <span>Strategy / Operations / Government</span>
                </div>
            </a>
            <nav class="nav" aria-label="Primary">
                <a href="/" class="{% if page == 'index' %}active{% endif %}">Home</a>
                <a href="/about.html" class="{% if page == 'about' %}active{% endif %}">About</a>
                <a href="/practices.html" class="{% if page == 'practices' %}active{% endif %}">Practices</a>
                <a href="/careers.html" class="{% if page == 'careers' %}active{% endif %}">Careers</a>
                <a href="/contact.html" class="nav-cta">Get in touch</a>
            </nav>
        </div>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <h3>Meridian Advisory</h3>
                <p>A boutique management consulting firm based in Perth, working with mid-market and government clients across Western Australia. Founded 2014.</p>
            </div>
            <div class="footer-col">
                <h4>Firm</h4>
                <ul>
                    <li><a href="/about.html">About</a></li>
                    <li><a href="/practices.html">Practices</a></li>
                    <li><a href="/careers.html">Careers</a></li>
                    <li><a href="/contact.html">Contact</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>For Staff</h4>
                <ul>
                    <li><a href="/staff/">Staff portal</a></li>
                    <li><a href="/staff/directory.html">Directory</a></li>
                    <li><a href="/staff/documents.html">Documents</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Affiliations</h4>
                <ul>
                    <li><a href="#">CMC Australia</a></li>
                    <li><a href="#">Probity standards</a></li>
                    <li><a href="#">Independence policy</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; {{ year }} MERIDIAN ADVISORY PARTNERSHIP / ABN 00 000 000 000</p>
            <p class="footer-disclaimer">A fictional firm, made for a Curtin University internship simulation.</p>
        </div>
    </footer>
{% if chatbot_embed_id %}
<!-- AnythingLLM hiring desk chatbot -->
<script
  data-embed-id="{{ chatbot_embed_id }}"
  data-base-api-url="{{ chatbot_base_api_url }}"
  src="{{ chatbot_widget_src }}">
</script>
{% endif %}
</body>
</html>
