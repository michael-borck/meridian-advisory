{% extends "base.html.j2" %}

{% block title %}{{ job.title }} — Meridian Advisory{% endblock %}

{% block content %}
<section class="hero">
    <div class="marg">
        <aside class="marg-aside hero-aside">
            <p class="section-num">Role</p>
            <p class="label" style="margin-top: var(--md-px-4);">
                <a href="/careers.html" style="color: var(--md-accent); border-bottom: 1px solid var(--md-accent);">← All positions</a>
            </p>
        </aside>
        <div>
            <p class="eyebrow">{{ job.department or "Open position" }}</p>
            <h1 class="display" style="font-size: clamp(2.25rem, 5vw, 4rem);">{{ job.title }}</h1>
            <p class="hero-tagline">{{ job.brief or job.summary or "" }}</p>

            <div class="hero-meta">
                <div class="hero-meta-item">
                    <div class="hero-meta-num" style="font-size: 1.4rem;">{{ job.employment_type or "Full-time" }}</div>
                    <div class="hero-meta-label">Type</div>
                </div>
                {% if job.reports_to %}
                <div class="hero-meta-item">
                    <div class="hero-meta-num" style="font-size: 1.4rem;">{{ job.reports_to }}</div>
                    <div class="hero-meta-label">Reports to</div>
                </div>
                {% endif %}
                <div class="hero-meta-item">
                    <div class="hero-meta-num" style="font-size: 1.4rem;">Perth WA</div>
                    <div class="hero-meta-label">Location</div>
                </div>
                <div class="hero-meta-item">
                    <div class="hero-meta-num" style="font-size: 1.4rem;">3<span class="unit">/yr</span></div>
                    <div class="hero-meta-label">Intake cohorts</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="marg">
        <aside class="marg-aside">
            <p class="section-num">02 / Detail</p>
        </aside>
        <div>
            {% if job.description %}
            <article class="prose">
                {{ job.description | markdown }}
            </article>
            {% endif %}
        </div>
    </div>
</section>

<section class="apply-section" id="apply">
    <div class="marg">
        <aside class="marg-aside">
            <span class="label">Apply</span>
            <p class="section-num" style="margin-top: var(--md-px-2);">03 / Submit</p>
        </aside>
        <div>
            <p class="eyebrow">Apply for this role</p>
            <h2>Submit your application.</h2>
            <p class="hero-tagline">A CV and a one-page letter on a problem you have helped solve. Read by a partner, replied to within five business days.</p>

            <form id="apply-form" class="apply-form" data-api-base="https://workready-api.eduserver.au">
                <input type="hidden" name="posting_id" value="">
                <input type="hidden" name="job_title" value="{{ job.title }}">
                <div>
                    <label for="applicant_name">Full name <span class="apply-required">*</span></label>
                    <input type="text" name="applicant_name" id="applicant_name" required>
                </div>
                <div>
                    <label for="applicant_email">Email address <span class="apply-required">*</span></label>
                    <input type="email" name="applicant_email" id="applicant_email" required placeholder="firstname.lastname@student.curtin.edu.au">
                </div>
                <div>
                    <label for="cover_letter">Cover letter</label>
                    <textarea name="cover_letter" id="cover_letter" rows="5" placeholder="Tell us why you're a good fit for this role…"></textarea>
                </div>
                <div>
                    <label for="resume">Resume (PDF) <span class="apply-required">*</span></label>
                    <input type="file" name="resume" id="resume" accept=".pdf" required>
                </div>
                <div>
                    <button type="submit" class="btn btn-primary btn-arrow">Submit application</button>
                </div>
                <div id="apply-result" class="apply-result"></div>
            </form>
        </div>
    </div>
</section>
{% endblock %}

{% block head_extra %}
<script src="/scripts/apply.js" defer></script>
{% endblock %}
